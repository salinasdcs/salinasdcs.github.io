---
layout: default
---
{% comment %}
  Local override of al_folio_core's cv layout.
  Intent (preserved from the pre-v1 site): show the CV as an embedded PDF
  instead of rendering a structured CV from cv.yml / resume.json.
  Set the PDF via `cv_pdf` in _pages/cv.md.
{% endcomment %}
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          {% if page.cv_pdf contains '://' %}
            href="{{ page.cv_pdf }}"
          {% else %}
            href="{{ page.cv_pdf | relative_url }}"
          {% endif %}
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
          title="Download CV (PDF)"
        >
          <i class="fa-solid fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    {% if page.cv_pdf %}
      <iframe
        src="{% if page.cv_pdf contains '://' %}{{ page.cv_pdf }}{% else %}{{ page.cv_pdf | relative_url }}{% endif %}"
        width="100%"
        height="800px"
        style="border: none;"
        title="{{ page.title }}"
      ></iframe>
    {% else %}
      <p>No CV PDF configured. Set <code>cv_pdf</code> in the page front matter.</p>
    {% endif %}
  </article>
</div>
